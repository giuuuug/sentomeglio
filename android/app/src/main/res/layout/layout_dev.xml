<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBg">

    <!-- Outer ScrollView so all content is reachable -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Content padding -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingBottom="16dp">

                <!-- STFT params -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PARAMETRI FFT"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="n_fft"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurfaceVar"
                            android:layout_marginBottom="3dp" />
                        <EditText
                            android:id="@+id/nFftInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="512"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorPrimary"
                            android:textAlignment="center"
                            android:background="@drawable/bg_input_field"
                            android:padding="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hop_len"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurfaceVar"
                            android:layout_marginBottom="3dp" />
                        <EditText
                            android:id="@+id/hopLengthInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="128"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorPrimary"
                            android:textAlignment="center"
                            android:background="@drawable/bg_input_field"
                            android:padding="8dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="4dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="win_len"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurfaceVar"
                            android:layout_marginBottom="3dp" />
                        <EditText
                            android:id="@+id/winLengthInput"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="number"
                            android:text="320"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorPrimary"
                            android:textAlignment="center"
                            android:background="@drawable/bg_input_field"
                            android:padding="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Model ONNX -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MODELLO ONNX"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/modelSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Audio devices -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISPOSITIVI AUDIO"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Input"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:layout_marginBottom="3dp" />
                <Spinner
                    android:id="@+id/inputSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Output"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:layout_marginBottom="3dp" />
                <Spinner
                    android:id="@+id/outputSpinner"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_spinner"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- REC/STOP button -->
                <Button
                    android:id="@+id/recButton"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="REC"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.08"
                    android:background="@drawable/bg_rec_dev_idle"
                    android:textColor="@color/colorPrimary"
                    android:layout_marginBottom="16dp"
                    android:elevation="0dp" />

                <!-- Status -->
                <TextView
                    android:id="@+id/statusText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ready"
                    android:gravity="center"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp" />

                <!-- Latency -->
                <TextView
                    android:id="@+id/latencyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="HW: N/A  |  DSP: N/A  |  Infer: N/A"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:layout_marginBottom="2dp" />

                <!-- RT metrics: RTF -->
                <TextView
                    android:id="@+id/metricsText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="RTF: N/A"
                    android:gravity="center"
                    android:fontFamily="monospace"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:layout_marginBottom="16dp" />

                <!-- Spectrograms -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SPETTROGRAMMI"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="NOISY"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurfaceVar"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />
                        <com.sentomeglio.app.SpectrogramView
                            android:id="@+id/specIn"
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="#000000" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="6dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="DENOISED"
                            android:textSize="9sp"
                            android:fontFamily="monospace"
                            android:textColor="@color/colorOnSurfaceVar"
                            android:letterSpacing="0.1"
                            android:layout_marginBottom="4dp" />
                        <com.sentomeglio.app.SpectrogramView
                            android:id="@+id/specDen"
                            android:layout_width="match_parent"
                            android:layout_height="90dp"
                            android:background="#000000" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Console -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CONSOLE"
                    android:textSize="11sp"
                    android:textColor="@color/colorOnSurfaceVar"
                    android:letterSpacing="0.08"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="6dp" />

                <ScrollView
                    android:id="@+id/consoleScroll"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:background="@color/colorConsoleBg"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:id="@+id/consoleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textColor="@color/colorOnSurface"
                        android:fontFamily="monospace"
                        android:textSize="10sp"
                        android:padding="8dp"
                        android:textIsSelectable="false" />
                </ScrollView>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
