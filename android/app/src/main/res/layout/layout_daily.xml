<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBg">


    <!-- Center: button + timer + hint -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <!-- Timer row (shown while recording) -->
        <LinearLayout
            android:id="@+id/timerRow"
            android:layout_width="wrap_content"
            android:layout_height="28dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="32dp"
            android:visibility="invisible">

            <View
                android:id="@+id/recDot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/shape_dot_error" />

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="00:00"
                android:textSize="22sp"
                android:fontFamily="monospace"
                android:textColor="@color/colorOnSurface"
                android:letterSpacing="0.1" />
        </LinearLayout>

        <!-- REC button container (pulse ring + button) -->
        <FrameLayout
            android:layout_width="120dp"
            android:layout_height="120dp">

            <!-- Pulse ring animated behind the button -->
            <View
                android:id="@+id/pulseRing"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/shape_circle_pulse"
                android:alpha="0" />

            <Button
                android:id="@+id/recButton"
                android:layout_width="120dp"
                android:layout_height="120dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_rec_idle"
                android:text=""
                android:elevation="0dp" />
        </FrameLayout>

        <!-- Status hint -->
        <TextView
            android:id="@+id/statusHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="Tocca per iniziare la registrazione"
            android:textSize="12sp"
            android:textColor="@color/colorOnSurfaceVar"
            android:alpha="0.7"
            android:letterSpacing="0.02" />
    </LinearLayout>

    <!-- Device selection -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Input"
            android:textSize="11sp"
            android:textColor="@color/colorOnSurfaceVar"
            android:layout_marginBottom="3dp" />
        <Spinner
            android:id="@+id/inputSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Output"
            android:textSize="11sp"
            android:textColor="@color/colorOnSurfaceVar"
            android:layout_marginBottom="3dp" />
        <Spinner
            android:id="@+id/outputSpinner"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@drawable/bg_spinner"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:layout_marginBottom="8dp" />
    </LinearLayout>

    <!-- Waveform at bottom -->
    <com.sentomeglio.app.WaveformView
        android:id="@+id/waveformView"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="24dp" />

</LinearLayout>
