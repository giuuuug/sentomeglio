<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/colorBg">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        android:background="@color/colorBg"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/colorBg"
            app:title="Impostazioni"
            app:titleTextColor="@color/colorOnSurface"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/colorOnSurface" />

    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="24dp">

            <!-- Section: Modalità -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="MODALITÀ"
                android:textSize="11sp"
                android:textColor="@color/colorPrimary"
                android:letterSpacing="0.08"
                android:fontFamily="sans-serif-medium"
                android:paddingTop="12dp"
                android:paddingBottom="8dp" />

            <!-- Card with developer toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_card"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <!-- Icon -->
                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_dev_icon"
                    android:layout_marginEnd="16dp">
                    <ImageView
                        android:id="@+id/devIcon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_dev" />
                </LinearLayout>

                <!-- Label -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Modalità Developer"
                        android:textSize="15sp"
                        android:textColor="@color/colorOnSurface" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Parametri FFT, spettrogrammi e console log"
                        android:textSize="12sp"
                        android:textColor="@color/colorOnSurfaceVar"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <!-- Toggle -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/devModeSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:thumbTint="@color/colorPrimary"
                    android:trackTint="@color/colorPrimaryBg" />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
